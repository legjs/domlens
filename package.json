{
  "name": "domlens-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for DomLens - Chrome extension and documentation website",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:extension": "pnpm --filter @domlens/extension dev",
    "build:extension": "pnpm --filter @domlens/extension build",
    "dev:website": "pnpm --filter @domlens/website dev",
    "build:website": "pnpm --filter @domlens/website build",
    "dev:runtime": "pnpm --filter @domlens/runtime dev",
    "build:runtime": "pnpm --filter @domlens/runtime build",
    "start:runtime": "pnpm --filter @domlens/runtime start",
    "build": "pnpm build:runtime && pnpm build:extension && pnpm build:website"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  }
}
